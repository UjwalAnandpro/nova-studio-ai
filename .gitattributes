# Auto-detect text files and normalize line endings to LF on commit
* text=auto

# Enforce LF for code files
*.py text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.txt text eol=lf
*.css text eol=lf
*.html text eol=lf
*.js text eol=lf

# Enforce CRLF for Windows batch files
*.bat text eol=crlf
*.cmd text eol=crlf

# Handle binary formats
*.ico binary
*.png binary
*.jpg binary
*.jpeg binary
*.zip binary
*.db binary
*.safetensors binary
