{
    "3": {
        "class_type": "KSampler",
        "inputs": {
            "seed": "${SEED}",
            "steps": "${STEPS}",
            "cfg": 7.0,
            "sampler_name": "euler",
            "scheduler": "normal",
            "denoise": 1.0,
            "model": ["4", 0],
            "positive": ["6", 0],
            "negative": ["7", 0],
            "latent_image": ["5", 0]
        }
    },
    "4": {
        "class_type": "CheckpointLoaderSimple",
        "inputs": {
            "ckpt_name": "svd_xt.safetensors"
        }
    },
    "5": {
        "class_type": "EmptyLatentVideo",
        "inputs": {
            "width": 1024,
            "height": 576,
            "length": 16,
            "batch_size": 1
        }
    },
    "6": {
        "class_type": "CLIPTextEncode",
        "inputs": {
            "text": "${PROMPT}",
            "clip": ["4", 1]
        }
    },
    "7": {
        "class_type": "CLIPTextEncode",
        "inputs": {
            "text": "shaky, static, bad quality",
            "clip": ["4", 1]
        }
    },
    "8": {
        "class_type": "VAEDecode",
        "inputs": {
            "samples": ["3", 0],
            "vae": ["4", 2]
        }
    },
    "9": {
        "class_type": "VHS_VideoCombine",
        "inputs": {
            "images": ["8", 0],
            "frame_rate": 24,
            "loop_count": 0,
            "filename_prefix": "NovaVideo",
            "format": "video/h264-mp4"
        }
    }
}
