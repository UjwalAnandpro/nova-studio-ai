# Nova Studio AI - Environment Settings Example

# Local storage path overrides
NOVA_STORAGE_PATH=storage
NOVA_CACHE_PATH=cache

# Third-party endpoints URL addresses
COMFYUI_SERVER_ADDRESS=http://127.0.0.1:8188

# OpenRouter API secrets (stored encrypted inside settings.json in production)
OPENROUTER_API_KEY=your-api-key-here
